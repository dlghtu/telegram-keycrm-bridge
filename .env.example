# === Server ===
PORT=3000
# Публичный HTTPS URL после деплоя (без слэша в конце), например:
# https://your-service.onrender.com
PUBLIC_BASE_URL=https://your-service.onrender.com

# === Telegram ===
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Опционально: секрет для проверки вебхука Telegram (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=
# ID менеджеров, которым разрешено /order (через запятую). Пусто = любой пользователь.
# Узнать свой id: напишите боту /start и смотрите логи, или @userinfobot
MANAGER_TELEGRAM_IDS=

# === KeyCRM ===
# API-ключ: KeyCRM → Налаштування → API / інтеграції
# Документация: https://docs.keycrm.app/
KEYCRM_API_TOKEN=your_keycrm_api_token
KEYCRM_API_BASE=https://openapi.keycrm.app/v1
# ID джерела (source) — обов'язкове поле при створенні замовлення
# GET https://openapi.keycrm.app/v1/order/source
KEYCRM_SOURCE_ID=1
# ID служби доставки «Нова Пошта» у KeyCRM (опційно)
# GET https://openapi.keycrm.app/v1/order/delivery-service
KEYCRM_NOVA_POSHTA_SERVICE_ID=
# Секрет, який ви самі задаєте і вказуєте в URL вебхука KeyCRM
# Приклад URL: https://your-service.onrender.com/webhooks/keycrm?secret=xxx
KEYCRM_WEBHOOK_SECRET=change_me_to_random_string

# === Маппинг chat_id (файл на диске; на free-tier Render без диска — in-memory) ===
# Якщо вказано — зберігаємо orderId → telegramChatId у файл
ORDERS_MAP_FILE=./data/orders-map.json
